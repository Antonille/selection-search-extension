{
  "manifest_version": 3,
  "name": "Selection Search Launcher",
  "version": "2.0.0",
  "description": "Right-click selected text and open it with a configurable, grouped search menu backed by a JSON resource spec.",
  "permissions": [
    "contextMenus",
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "minimum_chrome_version": "114"
}